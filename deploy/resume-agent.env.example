# Secrets live only in /etc/lifeos/resume-agent.env on the VPS.
LLM_PROVIDER=custom
LLM_API_KEY=replace-with-secret
LLM_BASE_URL=http://172.19.0.1:4000/v1
LLM_MODEL=gemini-3.5-flash

MINERU_API_TOKEN=
MINERU_API_BASE=https://mineru.net
TAVILY_API_KEY=

RESUME_AGENT_HOME=/root/.resume-agent
SQLITE_PATH=/root/.resume-agent/data.db
CHROMA_PATH=/root/.resume-agent/chroma
FILES_ROOT=/root/.resume-agent/files

HOST=0.0.0.0
PORT=5173
DEBUG=false
CORS_ORIGINS=https://chat.19991023.xyz
INTERNAL_API_TOKEN=replace-with-independent-secret
MAX_UPLOAD_BYTES=20971520
