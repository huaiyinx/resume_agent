# === LLM 配置 ===
LLM_PROVIDER=deepseek           # openai / claude / deepseek / custom
LLM_API_KEY=                    # 用户填入，仅存本地
LLM_BASE_URL=https://api.deepseek.com  # DeepSeek 不带 /v1 后缀
LLM_MODEL=deepseek-v4-pro       # deepseek 用 deepseek-v4-pro

# === Embedding 配置 ===
EMBEDDING_PROVIDER=openai       # openai（兼容 DeepSeek 协议）
EMBEDDING_MODEL=text-embedding-3-small

# === MinerU 文档解析 API（可选，用于 JD 截图分析） ===
MINERU_API_TOKEN=                # 在 https://mineru.net/apiManage 获取
MINERU_API_BASE=https://mineru.net

# === Tavily Web 搜索 API（AI 导师建议增强）===
TAVILY_API_KEY=                  # 在 https://tavily.com 获取

# === 数据存储 ===
RESUME_AGENT_HOME=~/.resume-agent
SQLITE_PATH=~/.resume-agent/data.db
CHROMA_PATH=~/.resume-agent/chroma
FILES_ROOT=~/.resume-agent/files

# === 服务 ===
HOST=0.0.0.0
PORT=5173
DEBUG=false
CORS_ORIGINS=*
INTERNAL_API_TOKEN=
MAX_UPLOAD_BYTES=20971520
